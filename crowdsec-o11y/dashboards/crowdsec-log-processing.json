          },
          {
            "matcher": { "id": "byName", "options": "Underflow Rate" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Instantiated Rate" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 9,
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(cs_bucket_created_total{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "Instantiated Rate",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(cs_bucket_overflowed_total{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "Overflow Rate",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(cs_bucket_underflowed_total{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "Underflow Rate",
          "refId": "C"
        }

      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": {
              "mode": "line",
              "steps": [
                { "color": "transparent", "value": null },
                { "color": "red", "value": 0.1 }
              ]
            }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "id": 14,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le, endpoint, method)(rate(cs_lapi_request_duration_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])))",
          "legendFormat": "p99 {{method}} {{endpoint}}",
          "refId": "A"
        }
      ],
      "title": "LAPI P99 Latency",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 },
      "id": 105,
      "title": "🤖 Machines & Agents",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "LAPI request counts per registered machine agent for the selected time range. A machine with zero requests has stopped communicating with the LAPI — it is no longer pushing events and its host is effectively a detection blind spot.\n\nNote: CrowdSec v1.7+ removed the cs_machine_last_push / cs_machine_last_pull metrics. This panel uses cs_lapi_machine_requests_total as the best available proxy for agent liveness.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 1    },
              { "color": "green",  "value": 10   }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Machine" },
            "properties": [{ "id": "custom.width", "value": 280 }]
          },
          {
            "matcher": { "id": "byName", "options": "Instance" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          },
          {
            "matcher": { "id": "byName", "options": "LAPI Requests" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "gradient" }
              },
              { "id": "custom.width", "value": 160 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 51 },
      "id": 15,
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "LAPI Requests" }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (machine, instance)(increase(cs_lapi_machine_requests_total{instance=~\"$instance\"}[$__range]))",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "title": "Machine Agent Activity (LAPI Requests in Range)",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "machine":  "Machine",
              "instance": "Instance",
              "Value":    "LAPI Requests"
            }
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": { "names": ["Machine", "Instance", "LAPI Requests"] }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 59 },
      "id": 200,
      "title": "🩺 Engine Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Scrape health of the CrowdSec metrics endpoint. DOWN means Alloy cannot reach the metrics port — the service may be crashed or the port blocked. Alerting rules fire after 2 minutes in this state.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "red",   "index": 0, "text": "DOWN" },
                "1": { "color": "green", "index": 1, "text": "UP"   }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1    }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 60 },
      "id": 201,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["min"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "up{job=\"app-exporter\", app=\"crowdsec\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "Service Health",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Rate of new ban decisions arriving at the LAPI from all agents. Unlike 'Active Decisions' (a static gauge), this shows attack velocity — how fast new bans are being issued right now. A sustained spike indicates an active, ongoing campaign.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "red",    "value": 2     }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 60 },
      "id": 202,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(cs_alerts{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "Alerts/s",
          "refId": "A"
        }
      ],
      "title": "Alert Rate",
      "description": "Rate of new CrowdSec alerts being generated. Alerts are created when a detection bucket overflows — each alert typically becomes a ban decision. A rising value indicates active, ongoing attacks.\n\nNote: cs_lapi_decisions_received was removed in CrowdSec v1.7. cs_alerts is the best available proxy for detection velocity.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "LAPI availability proxy: shows 0% when CrowdSec is up and serving requests, 100% when it is unreachable (no metrics). CrowdSec v1.7 removed per-status-code labels from cs_lapi_route_requests_total, so granular error rate tracking is no longer possible from Prometheus metrics alone.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1    },
              { "color": "red",    "value": 5     }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 60 },
      "id": 203,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "absent(cs_lapi_route_requests_total{instance=~\"$instance\"}) * 100 or vector(0)",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "title": "LAPI Error Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "What percentage of detection bucket instantiations result in an overflow (a triggered alert). A baseline value of 1–5% is typical. A sudden spike means attack traffic is matching rules at an unusually high rate — useful for spotting mass scans and brute-force campaigns before active bans accumulate.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 10   },
              { "color": "red",    "value": 30    }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 60 },
      "id": 204,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 * sum(rate(cs_bucket_overflowed_total{instance=~\"$instance\"}[$__rate_interval])) / (sum(rate(cs_bucket_created_total{instance=~\"$instance\"}[$__rate_interval])) > 0)",
          "legendFormat": "Conversion %",
          "refId": "A"
        }
      ],
      "title": "Bucket → Alert Conversion",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 65 },
      "id": 205,
      "title": "⚡ Decision Velocity",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Rate of LAPI requests from each bouncer over time. Bouncers poll the LAPI to fetch the latest decision list and apply it at the firewall or proxy. A healthy bouncer shows a steady periodic polling rate. A flat line means the bouncer has stopped enforcing new decisions.\n\nNote: cs_lapi_decisions_received (which tracked per-action decision counts) was removed in CrowdSec v1.7. This panel uses cs_lapi_bouncer_requests_total as a replacement.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 66 },
      "id": 206,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (bouncer)(rate(cs_lapi_bouncer_requests_total{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{bouncer}}",
          "refId": "A"
        }
      ],
      "title": "Bouncer Polling Rate Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Per-scenario alert rate over time. Use this panel alongside 'Top Triggering Scenarios' to understand which attack pattern is driving any given surge. Rising individual scenario lines pinpoint the specific threat type — SSH brute-force, web scan, credential stuffing, etc.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 66 },
      "id": 207,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (scenario)(rate(cs_alerts{instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{scenario}}",
          "refId": "A"
        }
      ],
      "title": "Alert Rate by Scenario (Live Velocity)",
      "type": "timeseries"
    }
  ],
